package cinema.pricing

import com.cinema.supportservice.dto.PriceEvaluationRequest;
import com.cinema.supportservice.dto.PriceEvaluationResponse.BreakdownItem;
import java.util.List;

global List breakdown;

// 1. Base price (always first)
rule "Base price"
    salience 10
    no-loop true
    when
        $req: PriceEvaluationRequest( finalPrice == null )
    then
        modify($req) {
            setFinalPrice($req.getBasePrice())
        };

        BreakdownItem item = new BreakdownItem();
        item.setRuleName("Base price");
        item.setDescription("Initial base price applied");
        item.setAppliedValue(1.0);
        breakdown.add(item);
end

// 2. VIP multiplier
rule "VIP multiplier"
    salience 20
    no-loop true
    when
        $req: PriceEvaluationRequest( seatCategory == "VIP" )
    then
        Long current = $req.getFinalPrice();

        modify($req) {
            setFinalPrice(Math.round(current * 1.5))
        };

        BreakdownItem item = new BreakdownItem();
        item.setRuleName("VIP multiplier");
        item.setDescription("VIP seats have 1.5x multiplier");
        item.setAppliedValue(1.5);
        breakdown.add(item);
end

// 3. HOLIDAY promo (10% discount)
rule "HOLIDAY promo 10% off"
    salience 30
    no-loop true
    when
        $req: PriceEvaluationRequest( promoCode == "HOLIDAY" )
    then
        Long current = $req.getFinalPrice();

        modify($req) {
            setFinalPrice(Math.round(current * 0.9))
        };

        BreakdownItem item = new BreakdownItem();
        item.setRuleName("HOLIDAY promo");
        item.setDescription("10% discount for HOLIDAY promotion");
        item.setAppliedValue(0.9);
        breakdown.add(item);
end